{
  "name": "media-dock",
  "private": true,
  "version": "3.0.0-alpha.3",
  "type": "module",
  "main": "dist-electron/main.js",
  "description": "A compact local media download and processing desktop app.",
  "author": {
    "name": "Yifo"
  },
  "scripts": {
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version",
    "dev:web": "vite",
    "dev:electron": "node scripts/dev-electron.mjs",
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "build:web": "tsc -b && vite build --base ./",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run build:web && npm run build:electron",
    "test": "npm run build && node --test --test-concurrency=1",
    "test:local-path": "npm run build:electron && node --test tests/local-path.test.mjs",
    "test:runtime-executable": "npm run build:electron && node --test tests/runtime-executable.test.mjs",
    "test:windows-package": "node --test tests/windows-runtime-package.test.mjs",
    "test:renderer-actions": "npm run build:web && node --test tests/renderer-actions.test.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "electron .",
    "launch:mac": "zsh scripts/launch-mac.sh",
    "launch:mac:v3": "zsh scripts/launch-mac-v3-preview.sh",
    "dist": "npm run build && electron-builder --config electron-builder.config.cjs",
    "dist:mac": "zsh scripts/build-mac-share.sh",
    "dist:win": "node scripts/build-windows-native.mjs"
  },
  "dependencies": {
    "extract-zip": "^2.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0",
    "wait-on": "^9.0.4"
  },
  "overrides": {
    "tmp": "^0.2.6"
  }
}
